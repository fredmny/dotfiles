# Mako notification daemon
# Styled to match current Hypr/Waybar look.

sort=-time
layer=overlay
anchor=top-right

# Geometry
width=360
height=120
margin=12
outer-margin=10,12,12,12
padding=10
border-size=2
border-radius=10
max-visible=5

# Appearance
background-color=#1e1e2ef2
text-color=#cdd6f4
border-color=#89b4fa
progress-color=over #89b4fa

# Typography/icons
font=Agave Nerd Font 13
icons=1
max-icon-size=48
markup=1
format=<b>%s</b>\n%b

# Behavior
default-timeout=3500
ignore-timeout=1
group-by=app-name,summary
history=1
actions=1

[urgency=low]
border-color=#7f849c
default-timeout=2000

[urgency=normal]
border-color=#89b4fa
default-timeout=3500

[urgency=high]
border-color=#f38ba8
text-color=#f38ba8
default-timeout=0

[category=weekend-reminder]
default-timeout=0
border-color=#f9e2af
